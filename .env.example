# ===========================================================================
#  PlataformaFallback — FRONTEND (.env)
# ===========================================================================

# URL pública de la API backend (usada por el navegador)
NEXT_PUBLIC_API_URL=https://api.tu-dominio.com
# URL del WebSocket (normalmente igual al backend)
NEXT_PUBLIC_WS_URL=https://api.tu-dominio.com
# Idioma por defecto del producto
NEXT_PUBLIC_DEFAULT_LOCALE=es
NEXT_PUBLIC_APP_NAME=PlataformaFallback

NODE_ENV=production
PORT=3000
